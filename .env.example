# Supabase — получить на supabase.com после создания проекта
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=YOUR_SERVICE_KEY

# Resend — для email уведомлений о лидах (resend.com — бесплатно до 3000 писем/мес)
RESEND_API_KEY=re_YOUR_KEY

# Email для получения уведомлений о новых лидах
ADMIN_EMAIL=russia.lids@gmail.com

# Секрет для ISR revalidation
REVALIDATE_SECRET=RANDOM_SECRET_STRING_HERE

# Домен
NEXT_PUBLIC_SITE_URL=https://specrf.ru
